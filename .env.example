# ──────────────────────────────────────────────────────────────
# MAILSTORA — ENVIRONMENT VARIABLES EXAMPLE
# ──────────────────────────────────────────────────────────────

# --- SERVER (DEPLOY ON RENDER/RAILWAY) ---
PORT=5001
MONGODB_URI=mongodb+srv://...
REDIS_URL=redis://...
FIREBASE_PROJECT_ID=...
IMGBB_API_KEY=...
EMAIL_USER=...
EMAIL_PASS=...
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
JWT_SECRET=...
MASTER_OTP=333333

# --- CLIENT (DEPLOY ON NETLIFY) ---
# This must be the full URL of your deployed backend
NEXT_PUBLIC_API_URL=https://your-backend-url.onrender.com
# Use this in Server to allow CORS from your frontend
FRONTEND_URL=https://your-site.netlify.app
